rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUserDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userDocPath(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }

    function bookingDocPath(bookingId) {
      return /databases/$(database)/documents/bookings/$(bookingId);
    }

    function currentUserExists() {
      return isSignedIn() && exists(currentUserDocPath());
    }

    function currentUserData() {
      return get(currentUserDocPath()).data;
    }

    function currentUserIsActive() {
      return currentUserExists()
        && (
          !currentUserData().keys().hasAny(['isActive'])
          || currentUserData().isActive == true
        );
    }

    function isAdmin() {
      return currentUserIsActive() && currentUserData().role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userExists(userId) {
      return exists(userDocPath(userId));
    }

    function userData(userId) {
      return get(userDocPath(userId)).data;
    }

    function userIsActive(userId) {
      return userExists(userId)
        && (
          !userData(userId).keys().hasAny(['isActive'])
          || userData(userId).isActive == true
        );
    }

    function userIsAdmin(userId) {
      return userIsActive(userId) && userData(userId).role == 'admin';
    }

    function bookingAfter(bookingId) {
      return getAfter(bookingDocPath(bookingId)).data;
    }

    match /users/{userId} {
      allow read: if isOwner(userId)
        || isAdmin()
        || (currentUserIsActive() && resource.data.role == 'admin');

      allow create: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role == 'user'
        && request.resource.data.isActive == true
        && request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'displayName',
          'role',
          'isActive',
          'avatar',
          'phoneNumber',
          'organization',
          'createdAt',
          'updatedAt'
        ]);

      allow update: if currentUserIsActive()
        && isOwner(userId)
        && resource.data.uid == request.auth.uid
        && resource.data.role == 'user'
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.isActive == resource.data.isActive
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName',
          'avatar',
          'phoneNumber',
          'organization',
          'updatedAt'
        ]) || (
          isAdmin()
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.email == resource.data.email
          && request.resource.data.role == resource.data.role
          && request.resource.data.displayName == resource.data.displayName
          && request.resource.data.avatar == resource.data.avatar
          && request.resource.data.phoneNumber == resource.data.phoneNumber
          && request.resource.data.organization == resource.data.organization
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'isActive',
            'updatedAt'
          ])
        );

      allow delete: if false;
    }

    match /approvedEmails/{email} {
      allow get: if true;
      allow list: if isAdmin();
      allow create, update: if isAdmin()
        && request.resource.data.email == email
        && request.resource.data.role == 'user';
      allow delete: if isAdmin();
    }

    match /venues/{venueId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /appSettings/communications {
      allow read, write: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if currentUserIsActive();

      allow create: if currentUserIsActive()
        && currentUserData().role in ['user', 'admin']
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.guestEmail == request.auth.token.email
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasOnly([
          'userId',
          'venueId',
          'venueName',
          'guestName',
          'guestEmail',
          'guestPhone',
          'organization',
          'date',
          'startTime',
          'endTime',
          'startTimestamp',
          'endTimestamp',
          'eventTitle',
          'eventType',
          'expectedPax',
          'specialRequests',
          'status',
          'createdAt'
        ]);

      allow update: if (
        currentUserIsActive()
        && isOwner(resource.data.userId)
        && resource.data.status in ['pending', 'approved']
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.venueId == resource.data.venueId
        && request.resource.data.venueName == resource.data.venueName
        && request.resource.data.guestName == resource.data.guestName
        && request.resource.data.guestEmail == resource.data.guestEmail
        && request.resource.data.guestPhone == resource.data.guestPhone
        && request.resource.data.organization == resource.data.organization
        && request.resource.data.date == resource.data.date
        && request.resource.data.startTime == resource.data.startTime
        && request.resource.data.endTime == resource.data.endTime
        && request.resource.data.startTimestamp == resource.data.startTimestamp
        && request.resource.data.endTimestamp == resource.data.endTimestamp
        && request.resource.data.eventTitle == resource.data.eventTitle
        && request.resource.data.eventType == resource.data.eventType
        && request.resource.data.expectedPax == resource.data.expectedPax
        && request.resource.data.specialRequests == resource.data.specialRequests
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.status == 'cancelled'
        && request.resource.data.cancelledBy == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'cancelledAt',
          'cancelledBy'
        ])
      ) || (
        isAdmin()
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.venueId == resource.data.venueId
        && request.resource.data.venueName == resource.data.venueName
        && request.resource.data.guestName == resource.data.guestName
        && request.resource.data.guestEmail == resource.data.guestEmail
        && request.resource.data.guestPhone == resource.data.guestPhone
        && request.resource.data.organization == resource.data.organization
        && request.resource.data.date == resource.data.date
        && request.resource.data.startTime == resource.data.startTime
        && request.resource.data.endTime == resource.data.endTime
        && request.resource.data.startTimestamp == resource.data.startTimestamp
        && request.resource.data.endTimestamp == resource.data.endTimestamp
        && request.resource.data.eventTitle == resource.data.eventTitle
        && request.resource.data.eventType == resource.data.eventType
        && request.resource.data.expectedPax == resource.data.expectedPax
        && request.resource.data.specialRequests == resource.data.specialRequests
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'processedBy',
          'processedAt',
          'adminNotes'
        ])
        && request.resource.data.status in ['approved', 'rejected']
        && request.resource.data.processedBy == request.auth.uid
      );

      allow delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if currentUserIsActive()
        && resource.data.recipientUserId == request.auth.uid;

      allow create: if currentUserIsActive()
        && request.resource.data.keys().hasOnly([
          'recipientUserId',
          'type',
          'title',
          'message',
          'link',
          'bookingId',
          'readAt',
          'createdAt'
        ])
        && request.resource.data.readAt == null
        && (
          (
            request.resource.data.type == 'booking_pending'
            && bookingAfter(request.resource.data.bookingId).userId == request.auth.uid
            && bookingAfter(request.resource.data.bookingId).status == 'pending'
            && (
              request.resource.data.recipientUserId == request.auth.uid
              || userIsAdmin(request.resource.data.recipientUserId)
            )
          ) || (
            isAdmin()
            && request.resource.data.type in ['booking_approved', 'booking_rejected']
            && bookingAfter(request.resource.data.bookingId).status in ['approved', 'rejected']
            && bookingAfter(request.resource.data.bookingId).userId == request.resource.data.recipientUserId
          )
        );

      allow update: if currentUserIsActive()
        && resource.data.recipientUserId == request.auth.uid
        && request.resource.data.recipientUserId == resource.data.recipientUserId
        && request.resource.data.type == resource.data.type
        && request.resource.data.title == resource.data.title
        && request.resource.data.message == resource.data.message
        && request.resource.data.link == resource.data.link
        && request.resource.data.bookingId == resource.data.bookingId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.readAt is int
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt']);

      allow delete: if false;
    }
  }
}
