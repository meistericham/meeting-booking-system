# Frontend Firebase web app config (safe for client bundle)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Frontend email API toggle
VITE_EMAIL_ENABLED=false
VITE_EMAIL_API_URL=/api/send-email

# Server-side SMTP config
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ADMIN_NOTIFICATION_EMAILS=

# Server-side Firebase Admin credentials
# Required for secure email delivery:
# - verify Firebase ID token
# - read Firestore communication templates
# - load booking/user data on the server
# Source: Firebase Console -> Project Settings -> Service accounts -> Generate new private key
# Map JSON fields like this:
# - project_id   -> FIREBASE_ADMIN_PROJECT_ID
# - client_email -> FIREBASE_ADMIN_CLIENT_EMAIL
# - private_key  -> FIREBASE_ADMIN_PRIVATE_KEY
# Keep the private key on one line with escaped \n characters, for example:
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nABC...\n-----END PRIVATE KEY-----\n"
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
